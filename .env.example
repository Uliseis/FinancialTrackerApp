# --- Database (Neon Postgres) ---
# Pooled connection string from Neon console.
DATABASE_URL=

# --- Auth (NextAuth + GitHub OAuth) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# http://localhost:3000 in dev, your Vercel URL in prod.
NEXTAUTH_URL=http://localhost:3000
# GitHub OAuth app credentials. https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
# The single email allowed to sign in.
ALLOWED_EMAIL=

# --- Token encryption (AES-256-GCM) ---
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Enable Banking (PSD2 AIS) ---
# https://enablebanking.com/cp/  -> Applications
# Application ID (UUID) — used as JWT `kid`.
ENABLEBANKING_APPLICATION_ID=
# RSA private key (PEM). Either paste the multi-line PEM directly,
# or base64 the PEM into a single line: `base64 -i private.pem | tr -d '\n'`.
ENABLEBANKING_PRIVATE_KEY=
# Must match the redirect URL registered for the application.
# Defaults to ${NEXTAUTH_URL}/api/enablebanking/callback if unset.
ENABLEBANKING_REDIRECT_URL=

# --- Cron (optional) ---
# Bearer token Vercel Cron sends; also accepted on POST /api/enablebanking/sync.
CRON_SECRET=
