# --- Database (Neon Postgres) ---
# Pooled connection string from Neon console.
DATABASE_URL=

# --- Auth (NextAuth + GitHub OAuth) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# http://localhost:3000 in dev, your Vercel URL in prod.
NEXTAUTH_URL=http://localhost:3000
# GitHub OAuth app credentials. https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
# The single email allowed to sign in.
ALLOWED_EMAIL=

# --- Token encryption (AES-256-GCM) ---
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- GoCardless Bank Account Data ---
# https://bankaccountdata.gocardless.com/ -> User Secrets
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
